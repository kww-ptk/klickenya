# ═══════════════════════════════════════════
# Klickenya — Environment Variables Template
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=               # Supabase project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=              # Supabase service role key (server-side only, full access)

# ── Sanity CMS ────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=          # Sanity project ID (e.g. b9zd8u9f)
NEXT_PUBLIC_SANITY_DATASET=             # Sanity dataset name (e.g. production)
NEXT_PUBLIC_SANITY_STUDIO_URL=          # Sanity Studio URL for preview
SANITY_API_TOKEN=                       # Sanity API read token (read-only)
SANITY_WRITE_TOKEN=                     # Sanity API write token (for seed scripts)
SANITY_WEBHOOK_SECRET=                  # Sanity webhook signing secret

# ── Sanity Studio (apps/studio only) ──────
SANITY_STUDIO_PROJECT_ID=               # Same as NEXT_PUBLIC_SANITY_PROJECT_ID
SANITY_STUDIO_DATASET=                  # Same as NEXT_PUBLIC_SANITY_DATASET
SANITY_STUDIO_PREVIEW_URL=              # Preview URL for studio drafts

# ── Email (Resend) ────────────────────────
RESEND_API_KEY=                         # Resend API key for transactional emails
RESEND_WEBHOOK_SECRET=                  # Resend webhook signing secret (inbound replies)
ADMIN_EMAIL=                            # Admin email for notifications (e.g. klickenya@gmail.com)

# ── Site ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=                   # Public site URL (https://klickenya.com)
NEXT_PUBLIC_GUEST_REGISTRATION=         # Enable guest registration ("true" or "false")

# ── GoHighLevel CRM ──────────────────────
GHL_API_KEY=                            # GoHighLevel API key
GHL_LOCATION_ID=                        # GHL location/sub-account ID
GHL_PIPELINE_ID=                        # GHL pipeline ID for lead tracking
GHL_INBOUND_WEBHOOK_URL=               # GHL inbound webhook URL
GHL_STAGE_SCRAPED_ID=                   # Pipeline stage: Scraped
GHL_STAGE_CONTACTED_ID=                 # Pipeline stage: Contacted
GHL_STAGE_OPENED_ID=                    # Pipeline stage: Opened
GHL_STAGE_CLAIMED_ID=                   # Pipeline stage: Claimed
GHL_STAGE_ACTIVE_ID=                    # Pipeline stage: Active
GHL_STAGE_PAYING_ID=                    # Pipeline stage: Paying
GHL_STAGE_LOST_ID=                      # Pipeline stage: Lost

# ── Security / Cron ──────────────────────
CRON_SECRET=                            # Secret for authenticated cron endpoints
ALLOW_TEST_ENDPOINTS=                   # Set to "true" to enable test/debug API routes

# ── Payments (Paystack) ──────────────────
PAYSTACK_SECRET_KEY=                    # Paystack secret key (sk_live_/sk_test_) — ticket payments
PLATFORM_TICKET_FEE_BPS=500             # Platform fee on paid tickets in basis points (500 = 5%)

# ── AI (optional) ─────────────────────────
ANTHROPIC_API_KEY=                      # Anthropic API key (for AI features)

# ── Sentry ────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                 # Sentry DSN — find it in Sentry → Settings → Client Keys
SENTRY_AUTH_TOKEN=                      # Only needed for source map upload in CI/Vercel — not required for local dev
