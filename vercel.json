{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    { "source": "/blog/:path*", "destination": "/journal/:path*", "permanent": true },
    { "source": "/listing/:path*", "destination": "/stays/:path*", "permanent": true },
    { "source": "/kenya/watamu/beach/garoda-beach", "destination": "/experiences/watamu/garoda-beach", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "apps/web/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/backfill-embeddings",
      "schedule": "0 2 * * *"
    }
  ]
}
